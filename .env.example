# Discord Bot
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Database
DATABASE_URL=postgresql://eventforge:eventforge_secret@postgres:5432/eventforge?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Bot Configuration
BOT_DEFAULT_LOCALE=fr
BOT_DEFAULT_TIMEZONE=Europe/Paris
BOT_WIZARD_TIMEOUT_MS=900000

# pgAdmin (dev only)
PGADMIN_EMAIL=admin@eventforge.dev
PGADMIN_PASSWORD=admin_secret

# Logging
LOG_LEVEL=info
NODE_ENV=production
